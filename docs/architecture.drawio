      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===== Legend ===== -->
        <mxCell id="lg" value="สีเส้น:  🟢 ช่วง1 รับงาน (เร็ว)   🟠 ช่วง2 ประมวลผล (ช้า เบื้องหลัง)   🔵 ช่วง3 รายงานผล (poll)" style="text;html=1;align=left;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="30" as="geometry" />
        </mxCell>

        <!-- ===== Nodes ===== -->
        <mxCell id="user" value="👤 User&#10;(ผู้ใช้)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="70" width="150" height="56" as="geometry" />
        </mxCell>

        <mxCell id="react" value="Frontend · React&#10;อัปโหลด · poll สถานะ · โชว์ผล&#10;(เก็บ state ใน localStorage)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="370" y="200" width="230" height="80" as="geometry" />
        </mxCell>

        <mxCell id="fastapi" value="Backend · FastAPI (:8000)&#10;validate · เขียนไฟล์ · โยนงาน&#10;ตอบสถานะ · rate limit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;spacingTop=4;" vertex="1" parent="1">
          <mxGeometry x="370" y="370" width="230" height="86" as="geometry" />
        </mxCell>

        <mxCell id="storage" value="Storage (ชั่วคราว)&#10;storage/{job_id}/&#10;วิดีโอ · เสียง · transcript · ผล&#10;+ audio hash cache · ลบ 7 วัน" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;spacingTop=4;" vertex="1" parent="1">
