# ─── Google Gemini API Keys ──────────────────────────────────────────────────
# รองรับหลาย key — คั่นด้วยเครื่องหมาย "," (ไม่มีช่องว่าง)
# ถ้า key 1 quota หมด → ระบบจะ switch ไป key 2 อัตโนมัติ
#
# ขอ key ได้ฟรีจาก: https://aistudio.google.com/app/apikey
#
# ตัวอย่าง (1 key) : GEMINI_API_KEYS=AIzaSy....
# ตัวอย่าง (3 keys): GEMINI_API_KEYS=AIzaSy....,AIzaSy....,AIzaSy....
GEMINI_API_KEYS=your_gemini_api_key_here

# ─── Redis ──────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Security (ปล่อยว่าง = ปิด สำหรับ dev / ตั้งค่า = เปิดสำหรับ production) ──────
# API key: ปล่อยว่าง = ไม่ต้อง auth. ตั้งค่า (คั่นด้วย ,) = /upload,/render ต้องส่ง header X-API-Key
# frontend ต้อง build ด้วย VITE_API_KEY ให้ตรงกับค่าตัวใดตัวหนึ่งนี้
API_KEYS=
# CORS: โดเมนที่อนุญาต (คั่นด้วย ,) — ปล่อยว่าง = localhost. deploy จริงใส่ https://yourdomain.com
ALLOWED_ORIGINS=
# Rate limit ต่อ IP (รูปแบบ slowapi เช่น 20/hour, 5/minute)
UPLOAD_RATE_LIMIT=20/hour
RENDER_RATE_LIMIT=60/hour

# ─── Cleanup ────────────────────────────────────────────────────────────────
# ลบ job เก่ากว่ากี่วัน (cleanup รันทุกวันตี 3 ผ่าน celery beat)
# PDPA: ยิ่งสั้นยิ่งดีถ้าเปิดสาธารณะ (เช่น 1 = ลบภายใน 24 ชม.)
JOB_RETENTION_DAYS=7

# ─── Observability — Sentry (ปล่อยว่าง = ปิด) ────────────────────────────────
# ใส่ DSN จาก sentry.io → จับ exception ทั้ง FastAPI + Celery อัตโนมัติ
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.0
